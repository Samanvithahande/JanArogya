# Frontend + Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend proxy target (required in production)
# Example: https://your-backend.onrender.com
BACKEND_URL=

# Optional client-side direct backend fallback
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_BACKEND_URL=

# Optional API base used by dashboard pages
# Keep as /api to use Next.js route handlers
# or set absolute URL to call backend directly.
NEXT_PUBLIC_API_BASE=/api
